# Auto detect text files and normalize to LF
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf

# Config & data
*.csv text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.rst text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Web
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# CI
*.yml text eol=lf

# Binary - don't touch
*.parquet binary
*.so binary
*.pyc binary
*.mat binary
*.sav binary
*.npz binary
*.npy binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.tar binary
*.gz binary
